data["Education_Level"] = LE.fit_transform(data["Education_Level"])

# hot Encoding
cols = ["Employment_Status","Marital_Status","Loan_Purpose","Property_Area","Gender","Employer_Category"]
one_hot = OneHotEncoder(drop="first", sparse_output=False, handle_unknown="ignore")
encoded = one_hot.fit_transform(data[cols])
encoded_df = pd.DataFrame(encoded, columns=one_hot.get_feature_names_out(cols), index = data.index)
encoded_df
# to put it into the data 
data = pd.concat([data.drop(columns=cols),encoded_df], axis = 1)
