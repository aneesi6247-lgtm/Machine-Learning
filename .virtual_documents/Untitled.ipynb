import pandas as pd
import seaborn as sns


ins_data = pd.read_csv("insurance.csv")
ins_data.head()


sns.scatterplot(
    data = ins_data,
    x = "bmi", 
    y = "charges",
    hue = "smoker")


# In ML we divide the data in x(input values), y(output values)
x = ins_data.drop(columns = ["region", "charges"])
y = ins_data["charges"]
x.head()
y.head()


# maping in the data
x["sex"].unique()
x["sex"] = x["sex"].map({"female": 1, "male": 0})
x["smoker"]= x["smoker"].map({"yes": 1, "no":0})
x


# Train test Split
import numpy as np
from sklearn.model_selection import train_test_split
x_train, x_test, y_train, y_test = train_test_split(
    x, y, test_size=0.2, random_state=42)



x_train


x_test


# train the model
from sklearn.linear_model import LinearRegression
model = LinearRegression()
model.fit(x_train, y_train)



# Prediction values
predicted_values=model.predict(x_test)
predicted_values


y_test


# Evaluete the resutls
# R-squre values
from sklearn.metrics import r2_score
r2_value = r2_score(y_test, predicted_values)
print("r2 value is", r2_value)


# to get the adjusted r2 value


x_test.shape


x_test.shape



